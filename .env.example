# ==========================================
# ⚙️ CONFIGURAÇÕES DO BANCO DE DADOS (SUPABASE)
# ==========================================
VITE_SUPABASE_PROJECT_ID="seu-project-id"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"

# ⚠️ A SECRET KEY (sb_secret_...) NUNCA vai aqui no .env do frontend.
# Use somente em Supabase Edge Functions ou backend privado:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=sua_secret_aqui

# ==========================================
# 🔍 AUTOMAÇÃO DE PESQUISA / SCRAPING (APIFY)
# ==========================================
VITE_APIFY_API_KEY="apify_api_xxxxx"

# ==========================================
# 🧠 CHAVES DE INTELIGÊNCIA ARTIFICIAL (I.A.)
# ==========================================

# 1. Google Gemini (Principal - Agentes, Textos e Propostas)
VITE_GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# 2. Hugging Face (Mistral - IA de Segurança/Plano B)
VITE_HUGGINGFACE_KEY="hf_xxxxx"

# 3. Groq (Llama 3)
VITE_GROQ_KEY=""

# ==========================================
# 🔐 ERPNext Integration (Edge Functions Secrets - sem prefixo VITE_)
# ==========================================
ERPNEXT_URL="https://seu-erpnext.com"
ERPNEXT_API_KEY="api_key_gerado_no_usuario"
ERPNEXT_API_SECRET="api_secret_gerado_no_usuario"
