# .env file template
# Copy these to a .env local file to develop with Supabase Local
# Or if using Supabase Edge functions, set them via Supabase CLI: 
# `supabase secrets set ERPNEXT_URL=https://...`

VITE_SUPABASE_URL="SUA_URL_AQUI"
VITE_SUPABASE_ANON_KEY="SUA_CHAVE_AQUI"

# ERPNext Integration (Server-side Edge Functions Secrets)
# Do NOT prefix with VITE_ so they don't leak to the frontend React app!
ERPNEXT_URL="https://seu-erpnext.com"
ERPNEXT_API_KEY="api_key_gerado_no_usuario"
ERPNEXT_API_SECRET="api_secret_gerado_no_usuario"
